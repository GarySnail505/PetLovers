# Copie este archivo como .env y complete los valores locales.
# Identidad de esta instalación: inaquito o cumbaya.
LOCAL_NODE=inaquito

# La aplicación se conecta exclusivamente al SQL Server de este computador.
# Use localhost, localhost\INSTANCIA o el nombre local de la instancia.
LOCAL_SQL_SERVER=localhost
LOCAL_SQL_PORT=1433
LOCAL_SQL_DATABASE=PetLoversInaquito
LOCAL_SQL_USER=pl_app_inaquito
LOCAL_SQL_PASSWORD=CAMBIAR_POR_LA_CONTRASENA_LOCAL

# Aplicación web
FLASK_SECRET_KEY=CAMBIAR_POR_UNA_CLAVE_ALEATORIA_LARGA
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000

# Driver ODBC instalado en Windows
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_ENCRYPT=no
SQL_TRUST_SERVER_CERTIFICATE=yes
SQL_CONNECTION_TIMEOUT=5
